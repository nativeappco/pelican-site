---
title: "Blog | Product Pelican"
description: "Field notes on Shopify PIM, product data, GEO, and agentic commerce from the team behind Product Pelican."
permalink: /blog/
pagination:
  data: collections.posts
  size: 12
  reverse: true
  alias: posts
---
{% extends "base.njk" %}

{% block content %}
<main class="blog-index">
  <header class="blog-index-header">
    <h1>The Product Pelican Blog</h1>
    <p>Field notes on Shopify PIM, product data, GEO, and agentic commerce.</p>
  </header>

  {% if posts.length %}
  <ul class="post-list">
    {%- for post in posts %}
    <li class="post-card">
      <a href="{{ post.url }}">
        <h2>{{ post.data.title }}</h2>
        <p class="post-card-meta"><time datetime="{{ post.date | isoDate }}">{{ post.date | postDate }}</time></p>
        <p class="post-card-desc">{{ post.data.description }}</p>
        <span class="post-card-more">Read article →</span>
      </a>
    </li>
    {%- endfor %}
  </ul>
  {% else %}
  <p>No articles yet — check back soon.</p>
  {% endif %}
</main>
{% endblock %}
